<style>
        .main-container {
                display: flex;
                flex-direction: column;
                justify-content: center;
                align-items: center;
        }

        a {
                color: unset;
        }

        .icons-container {
                display: flex;
                flex-wrap: wrap;
                justify-content: center;
                gap: 45px;
                margin-top: 36px;
        }

        .icon {
                width: 30px;
                height: 30px;
                display: flex;
                align-items: center;
                justify-content: center;
                border-radius: 14px;
                cursor: default;
                transition: all 0.25s ease;
        }

        .discord-container svg {
                object-fit: contain;
                transform: scale(1.6);
        }

        .icon svg {
                width: 28px;
                height: 28px;
                fill: currentColor;
        }

        .icon:hover {
                transform: translateY(-2.4px) scale(1.2);
        }

        .spotify-icon {
                transform: rotate(-3deg);
        }

        .github-container:hover {
                color: var(--color-brand-github);
        }
        .twitter-container:hover {
                color: var(--color-brand-twitter);
        }
        .linkedin-container:hover {
                color: var(--color-brand-linkedin);
        }
        .telegram-container:hover {
                color: var(--color-brand-telegram);
        }
        .discord-container:hover {
                color: var(--color-brand-discord);
        }
        .email-container:hover {
                color: var(--color-brand-email);
        }
        .chess-container:hover {
                color: var(--color-brand-github);
        }
        .bluesky-container:hover {
                color: var(--color-brand-bluesky);
        }
        .spotify-container:hover {
                color: var(--color-brand-spotify);
        }
        @media (max-width: 768px) {
                .icons-container {
                        gap: 30px;
                        max-width: 350px;
                }
        }
</style>
