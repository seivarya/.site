---
import Clock from "./clock.astro";
import Navigation from "./navigation.astro";
---

<header class="top-bar">
	<span class="est-badge">EST. 2005</span>
	<div class="clock-display">
		<a href="#">
			<img src="/src/assets/clock.svg" alt="clock" width="20" height="20" />
		</a>
		<Clock />
	</div>
</header>

<div class="avatar-wrapper">
	<img class="avatar-image" src="/self.png" width="90" height="90" alt="avatar" />
	<Navigation/>
</div>

<style>
.top-bar {
	display: flex;
	justify-content: space-between;
	align-items: center;
	letter-spacing: 1.5px;
	margin-bottom: 60px;
	font-size: 0.95rem;
	width: 100%;
}
.est-badge {
	color: #7b8496;
}
.clock-display {
	display: flex;
	align-items: center;
	gap: 10px;
	color: #7b8496;
}
.clock-display img {
	opacity: 0.8;
}
.avatar-wrapper {
	display: flex;
	gap: 50px;
	flex-direction: row;
	width: 100%;
	margin-bottom: 40px;
}
.avatar-image {
	border-radius: 10px;
	object-fit: cover;
}
</style>
