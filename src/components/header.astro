---
import Clock from "./clock.astro";
import Navigation from "./navigation.astro";
---

<header class="top-bar">
	<span class="est-badge">EST. 2005</span>
	<div class="clock-display">
		<img src="/src/assets/clock.svg" alt="clock" width="20" height="20" />
		<Clock />
	</div>
</header>

<div class="nav-section-wrapper">
	<div class="avatar-wrapper">
		<a href="/" class="avatar-link" aria-label="home" style="display: contents;">
			<img class="avatar-image" src="/self.png" width="90" height="90" alt="avatar" />
		</a>
		<Navigation/>
	</div>
</div>

<style>

.nav-section-wrapper {
	display: flex;
	justify-content: space-between;
	align-items: center;
}

.top-bar {
	display: flex;
	justify-content: space-between;
	align-items: center;
	letter-spacing: 1.5px;
	margin-bottom: 60px;
	font-size: 0.95rem;
	width: 100%;
}
.est-badge {
	color: var(--color-text-muted);
}
.clock-display {
	display: flex;
	align-items: center;
	gap: 10px;
	color: var(--color-text-muted);
}
.clock-display img {
	opacity: 0.8;
}
.avatar-wrapper {
	display: flex;
	flex-direction: row;
	justify-content: space-between;
	width: 100%;
	margin-bottom: 40px;
}
.avatar-image {
	filter: contrast(110%);
	border-radius: 10px;
	object-fit: cover;
}

@media (max-width: 826px) {
	.top-bar {
		margin-bottom: 40px;
	}
	.nav-section-wrapper {
		justify-content: center;
	}

	.avatar-wrapper {
		display: flex;
		flex-direction: row;
		gap: 50px;
	}
}
</style>
