<footer class="site-footer">
	<div class="footer-links">
		<span
		><a href="https://astro.build/" target="_blank">built with astro</a
			></span
		>
		<span class="dot">-</span>
		<a href="/rss.xml">rss</a>
		<span class="dot">-</span>
		<a href="/sitemap-index.xml">sitemap</a>
	</div>

	<div class="footer-bottom">
		<div class="loading-state">
			loading
			<span class="dots">
				<span class="dot-load">.</span>
				<span class="dot-load">.</span>
				<span class="dot-load">.</span>
			</span>
		</div>
		<div class="theme-toggle">
			<span><a href="https://github.com/seivarya/">source code</a></span>
		</div>
	</div>

	<div class="copyright">
		<a href="https://github.com/seivarya" target="_blank">
			&copy; <span id="current-year"></span>
			seivarya</a>
	</div>

</footer>

<script>
const currentYearElement = document.getElementById("current-year");
if (currentYearElement) {
	currentYearElement.textContent = String(new Date().getFullYear());
}
</script>

<style>
.site-footer {
	width: 100%;
	display: flex;
	flex-direction: column;
	align-items: center;
	gap: 25px;
	margin-top: auto;
	padding-top: 60px;
	font-family: inherit;
	font-size: 0.95rem;
}

.footer-links {
	display: flex;
	align-items: center;
	gap: 15px;
	color: #7b8496;
}

.footer-links span {
	color: #7b8496;
}

a {
	color: #7b8496;
	text-decoration: none;
	border-bottom: 1px solid #4b5263;
	transition:
		color 0.2s,
		border-color 0.2s;
	padding-bottom: 2px;
}

a:hover {
	color: #a0a8ba;
	border-bottom-color: #a0a8ba;
}

.copyright {
	margin: 0;
	display: flex;
	align-items: center;
	gap: 6px;
	color: #7b8496;
}

.footer-bottom {
	width: 100%;
	display: flex;
	justify-content: space-between;
	align-items: center;
	margin-top: 15px;
}

.loading-state {
	display: flex;
	align-items: center;
	color: #9ba1b0;
	letter-spacing: 1px;
}

.dots {
	margin-left: 6px;
	display: flex;
	gap: 6px;
}

.dot-load {
	animation: load-bounce 1.4s infinite both;
	display: inline-block;
}
.dot-load:nth-child(1) {
	animation-delay: 0s;
}
.dot-load:nth-child(2) {
	animation-delay: 0.2s;
}
.dot-load:nth-child(3) {
	animation-delay: 0.4s;
}

@keyframes load-bounce {
0%,
80%,
100% {
	transform: translateY(0);
	opacity: 0.4;
}
40% {
	transform: translateY(-3px);
	opacity: 1;
}
}

.theme-toggle {
	display: flex;
	align-items: center;
	color: #7b8496;
}
</style>
