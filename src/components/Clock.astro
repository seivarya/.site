<div id="clock-wrapper">
    <span id="current-time">--:--:--</span>
    <span class="gmt">| GMT+5:30</span>
</div>

<style>
    #clock-wrapper {
        display: flex;
        align-items: center;
        gap: 6px;
        color: #7b8496;
        font-family: inherit;
    }
</style>
<script>
    function updateClock() {
        const now = new Date();
        const seconds = now.getSeconds();
        const minutes = now.getMinutes();
        const hours = now.getHours();

        const timeDisplay = document.getElementById("current-time");
        if (!timeDisplay) {
            console.log("Clock display element not found");
            return;
        }

        timeDisplay.textContent =
            ("0" + hours).slice(-2) +
            ":" +
            ("0" + minutes).slice(-2) +
            ":" +
            ("0" + seconds).slice(-2);
    }
    setInterval(updateClock, 1000);
</script>
