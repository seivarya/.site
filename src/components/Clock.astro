<div id="clock_wrapper">
    <span id="clock_component_span">--:--:--</span>
    <span class="gmt">GMT+5:30</span>
</div>

<style>
    #clock_wrapper {
        display: flex;
        align-items: center;
        gap: 6px;
        color: #7b8496;
        font-family: inherit;
    }
</style><script>
    function time() {
        var date = new Date();
        var second = date.getSeconds();
        var minutes = date.getMinutes();
        var hours = date.getHours();

        var span = document.getElementById("clock_component_span");
        if (!span) {
            console.log("span error");
            return;
        }

        span.textContent =
            ("0" + hours).slice(-2) +
            ":" +
            ("0" + minutes).slice(-2) +
            ":" +
            ("0" + second).slice(-2);
    }
    setInterval(time, 1000);
</script>
