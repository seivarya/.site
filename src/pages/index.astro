---
import Home from "../layouts/home.astro";
import Socials from "../components/Socials.astro";
---

<Home>
        <section class="profile-section">
                <div class="name-container">
                        <p class="author-name">shivang</p>
                        <a class="author-role" href="/">backend developer</a>
                </div>
        </section>

        <section class="about-section">
                <div class="intro-section">
                        <p>
                                hey, it's shivang. i am a backend developer.
                                currently working with some low level stuff.
                                while also freelancing in web. i'm currently
                                working with:
                        </p><br />
                </div>

                <div class="tech-stack-section">
                        <span>c</span> | <span>python</span> | <span
                                >node.js</span
                        > | <span>git</span> | <span>neovim</span> | <span
                                >arch</span
                        >
                        <br /><br /><br />
                </div>

                <div class="contact-section">
                        if you want to work together, or have some feedback
                        regarding any of my projects, <br /><br />
                        shoot me a mail at:
                        <a class="email-link" href="mailto:hey@seivarya.in"
                                >hey@seivarya.in</a
                        ><br /><br />
                        in my free time, you'll usually find me playing games, reading
                        blogs or books, or watching shows. i have several social accounts
                        linked, but i'm not active on most of them. you'll get the
                        fastest response on <a
                                class="discord-link"
                                href="https::discord.com/users/1345276369566699530"
                                >discord</a
                        >.
                        <br /><br />
                </div>
        </section>
        <Socials />
</Home>

<style>
        .contact-section {
                margin-bottom: 40px;
        }
        @media (max-width: 600px) {
                .contact-section {
                        margin-bottom: 15px;
                }
        }
        a {
                color: unset;
        }
        .contact-section a,
        .contact-section a:visited,
        .contact-section a:active {
                text-decoration: none;
                border-bottom: 1px solid transparent;
                padding-bottom: 1px;
                font-weight: 500;
                transition:
                        border-bottom-color 0.25s ease,
                        opacity 0.25s ease;
        }

        .contact-section .friend-link {
                color: var(--color-text-primary);
                border-bottom: none;
        }
        .contact-section .email-link {
                color: var(--color-text-primary);
                border-bottom-color: rgba(255, 255, 255, 0.3);
        }
        .contact-section .discord-link {
                color: var(--color-brand-discord);
                border-bottom-color: rgba(157, 166, 255, 0.3);
        }

        .contact-section a:hover,
        .contact-section a:focus {
                opacity: 0.85;
        }
        .contact-section .email-link:hover {
                border-bottom-color: rgba(255, 255, 255, 1);
        }
        .contact-section .discord-link:hover {
                border-bottom-color: var(--color-brand-discord);
        }
        .about-section {
                display: flex;
                flex-direction: column;
                align-items: center;
                justify-content: center;
        }

        .tech-stack-section {
                color: var(--color-text-main);
                margin-top: 1px;
                text-align: left;
        }

        .profile-section {
                display: flex;
                gap: 16px;
        }
        .name-container {
                display: flex;
                flex-direction: column;
                gap: 10px;
        }
        .author-name {
                margin: 0;
                font-weight: bold;
                font-size: 1.5rem;
                color: var(--color-text-main);
                letter-spacing: 0.5px;
                display: inline-block;
        }
        .author-role {
                margin-top: 13px;
                width: fit-content;
                text-decoration: none;
                border-bottom: 1px solid var(--color-border);
                padding-bottom: 2px;
                color: var(--color-text-muted);
                font-weight: 300;
                font-size: 1.1rem;
                cursor: context-menu;
                transition:
                        color 0.25s ease,
                        border-bottom-color 0.25s ease;
        }
        .author-role:hover {
                color: var(--color-text-main);
                border-bottom-color: var(--color-text-main);
        }
        .perm-link {
                color: var(--color-text-main);
        }

        .intro-section {
                margin-top: 20px;
                line-height: 1.7;
                width: 100%;
                margin-bottom: 0px;
        }
        .intro-section p {
                margin: 0;
        }
</style>
