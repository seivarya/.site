---
import Home from "../layouts/home.astro";
import Footer from "../components/footer.astro";
import Socials from "../components/socials.astro";
---

<Home>
	<section class="profile-section">
		<div class="name-container">
			<h1 class="author-name">
				<a class="author-name" href="/">seivarya</a>
			</h1>
		</div>

		<a class="author-role" href="/">backend developer</a>
	</section>
	<section class="mid-section">
		<div class="intro-section">
			<p>
				hey, it's shivang. i am a backend developer (i think).
				currently working with some low level stuff. while also working freelance in web.
				in my free time, you'll usually find me writing , playing chess, or reading books. i'm currently working with:
			</p><br />
		</div>

		<div class="tech-stack-section">
			<span>c</span> · <span>python</span> · <span>node.js</span> · <span>git</span> · <span>neovim</span> · <span>arch</span> · <span>postgres</span><br /><br /><br />
		</div>

		<div class="end-section">
			If you want to work together, or have some feedback regarding any of my projects, 
			shoot me a mail at 
			<a href="mailto:hey@seivarya.in">hey@seivarya.in</a>
		</div>

	</section>
	<Socials/>
	<Footer />
</Home>

<style>
.end-section {
	margin-bottom:40px;
}
a {
	color: unset;
}
.end-section a {
	color: var(--color-text-muted);
	text-decoration: none;
	border-bottom: 1px solid var(--color-border);
	transition: color 0.2s, border-color 0.2s;
	padding-bottom: 2px;
}
.end-section a:hover {
	color: var(--color-text-hover);
	border-bottom-color: var(--color-text-hover);
}
.mid-section {
	display: flex;
	flex-direction: column;
	align-items: center;
	justify-content: center;
}

.tech-stack-section {
	color: var(--color-text-muted);
	margin-top: 1px;
	text-align: left;
}

.tech-stack-section span:hover {
	color: var(--color-text-main);
}
.profile-section {
	display: flex;
	flex-direction: column;
	gap: 16px;
}
.name-container {
	display: flex;
	align-items: center;
	gap: 10px;
}
.author-name {
	margin: 0;
	font-weight: bold;
	text-decoration: none;
	font-size: 1.5rem;
	color: var(--color-text-main);
	letter-spacing: 0.5px;
}
.author-name:hover {
	transform: scale(1.1);
}
.author-role {
	margin-top: 13px;
	width: fit-content;
	text-decoration: none;
	border-bottom: 1px solid var(--color-border);
	color: var(--color-text-muted);
	font-weight: 300;
	font-size: 1.1rem;
	cursor: context-menu;
}
.author-role:hover {
	color: var(--color-text-main);
}

.intro-section {
	margin-top: 20px;
	line-height: 1.7;
	color: var(--color-text-muted);
	width: 100%;
	margin-bottom: 0px;
}
.intro-section p {
	margin: 0;
}
</style>
