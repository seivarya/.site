---
import "../styles/global.css";
---

<!doctype html>
<html style="background-color: #050505;">
        <head>
                <meta charset="UTF-8" />
                <meta name="viewport" content="width=device-width" />
                <title>404 - Not Found</title>
                <meta name="theme-color" content="#050505" />
        </head>
        <body style="background-color: #050505; margin: 0;">
                <div class="error-container">
                        <img src="/404.webp" alt="404" class="error-img" />
                        <a href="/" class="home-link">go back home</a>
                </div>
        </body>
</html>

<style>
        .error-container {
                display: flex;
                flex-direction: column;
                align-items: center;
                justify-content: center;
                min-height: 100vh;
                gap: 20px;
                background-color: var(--color-bg-main, #050505);
        }

        .error-img {
                max-width: 90vw;
                max-height: 70vh;
                border-radius: 8px;
        }

        .home-link {
                color: var(--color-text-muted, #999999);
                text-decoration: underline;
                text-decoration-color: var(--color-border, #2a2a2a);
                text-underline-offset: 4px;
                font-family: inherit;
                transition:
                        color 0.2s,
                        text-decoration-color 0.2s;
        }

        .home-link:hover {
                color: var(--color-text-hover, #ffffff);
                text-decoration-color: var(--color-text-hover, #ffffff);
        }
</style>
