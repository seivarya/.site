---
import Home from "../layouts/home.astro";
---

<Home>
	<h1 class="page-title">UI Playground</h1>
	<p class="page-subtitle">Comparing 3 different layouts for the writings page.</p>

	<!-- ==============================================
OPTION 1: THE TERMINAL LOG 
============================================== -->
	<section class="test-section">
		<h2 class="section-heading">Option 1: The Terminal Log</h2>
		<div class="opt-1-log">
			<a href="#" class="log-item">
				<span class="log-date">[24-10-12]</span>
				<span class="log-title">building a neural network in lua</span>
				<span class="log-time">12m</span>
			</a>
			<a href="#" class="log-item">
				<span class="log-date">[24-09-05]</span>
				<span class="log-title">why c is still relevant for servers</span>
				<span class="log-time">08m</span>
			</a>
			<a href="#" class="log-item">
				<span class="log-date">[24-07-22]</span>
				<span class="log-title">rewriting my portfolio from scratch</span>
				<span class="log-time">04m</span>
			</a>
		</div>
	</section>

	<hr class="divider"/>

	<!-- ==============================================
OPTION 2: THE CLEAN INDEX 
============================================== -->
	<section class="test-section">
		<h2 class="section-heading">Option 2: The Clean Index</h2>
		<div class="opt-2-index">
			<a href="#" class="index-item">
				<span class="index-title">building a neural network in lua</span>
				<span class="index-date">Oct 12, 2024</span>
			</a>
			<a href="#" class="index-item">
				<span class="index-title">why c is still relevant for servers</span>
				<span class="index-date">Sep 05, 2024</span>
			</a>
			<a href="#" class="index-item">
				<span class="index-title">rewriting my portfolio from scratch</span>
				<span class="index-date">Jul 22, 2024</span>
			</a>
		</div>
	</section>

	<hr class="divider"/>

	<!-- ==============================================
OPTION 3: THE JOURNAL SNIPPET 
============================================== -->
	<section class="test-section">
		<h2 class="section-heading">Option 3: The Journal Snippet</h2>
		<div class="opt-3-journal">
			<a href="#" class="journal-item">
				<h3 class="journal-title">building a neural network in lua</h3>
				<span class="journal-meta">Oct 12, 2024 · 12 min read</span>
				<p class="journal-preview">If you're wondering how backpropagation actually works from scratch, breaking out of heavy wrappers and writing a pure NN in Lua teaches you exactly how gradients flow.</p>
			</a>
			<a href="#" class="journal-item">
				<h3 class="journal-title">why c is still relevant for servers</h3>
				<span class="journal-meta">Sep 05, 2024 · 08 min read</span>
				<p class="journal-preview">Modern abstractions are powerful, but sometimes you just need raw socket handling and absolute control over memory management to build a truly tiny web server.</p>
			</a>
		</div>
	</section>

</Home>

<style>
/* Base Page Styles */
.page-title {
	font-size: 1.5rem;
	margin: 0;
	color: var(--color-text-main);
}
.page-subtitle {
	font-size: 1.1rem;
	color: var(--color-text-muted);
	margin-top: 15px;
	margin-bottom: 60px;
}
.divider {
	border: 0;
	border-top: 1px dashed var(--color-border);
	margin: 60px 0;
	opacity: 0.5;
}
.section-heading {
	font-size: 1.2rem;
	color: var(--color-text-hover);
	margin-bottom: 30px;
	border-left: 4px solid var(--color-text-hover);
	padding-left: 10px;
}

/* ==============================================
OPTION 1 STYLES 
============================================== */
.opt-1-log {
	display: flex;
	flex-direction: column;
	gap: 15px;
	font-family: "SauceCodeProNFM", monospace;
}
.log-item {
	display: flex;
	gap: 20px;
	text-decoration: none;
	color: var(--color-text-primary);
	transition: color 0.1s ease;
}
.log-item .log-date {
	color: var(--color-text-muted);
	min-width: 105px;
}
.log-item .log-title {
	flex-grow: 1;
}
.log-item .log-time {
	color: var(--color-text-muted);
	opacity: 0.7;
}
.log-item:hover,
.log-item:hover .log-date,
.log-item:hover .log-title,
.log-item:hover .log-time {
	color: var(--color-text-main);
	opacity: 1;
}

/* ==============================================
OPTION 2 STYLES 
============================================== */
.opt-2-index {
	display: flex;
	flex-direction: column;
}
.index-item {
	display: flex;
	justify-content: space-between;
	align-items: center;
	padding: 16px 0;
	text-decoration: none;
	color: var(--color-text-primary);
	border-bottom: 1px solid var(--color-border);
	transition: color 0.2s ease, border-color 0.2s ease;
}
.index-date {
	color: var(--color-text-muted);
	font-size: 0.9rem;
	transition: color 0.2s ease;
}
.index-title {
	font-size: 1.1rem;
	transition: color 0.2s ease;
}
.index-item:hover .index-title,
.index-item:hover .index-date {
	color: var(--color-text-main);
}
.index-item:hover {
	border-bottom-color: var(--color-text-muted);
}

/* ==============================================
OPTION 3 STYLES 
============================================== */
.opt-3-journal {
	display: flex;
	flex-direction: column;
	gap: 40px;
}
.journal-item {
	display: flex;
	flex-direction: column;
	text-decoration: none;
	color: var(--color-text-primary);
	transition: opacity 0.2s ease;
}
.journal-item:hover {
	opacity: 0.8;
}
.journal-title {
	margin: 0 0 5px 0;
	font-size: 1.3rem;
	color: var(--color-text-main);
	font-weight: bold;
	transition: color 0.2s ease;
}
.journal-meta {
	font-size: 0.85rem;
	color: var(--color-text-muted);
	margin-bottom: 15px;
	text-transform: uppercase;
	letter-spacing: 0.5px;
}
.journal-preview {
	margin: 0;
	font-size: 1rem;
	line-height: 1.6;
	color: var(--color-text-muted);
}
.journal-item:hover .journal-title {
	color: var(--color-text-hover);
}
</style>
