---
import Home from "../layouts/home.astro";
import CleanIndex from "../components/clean_index.astro";
import Footer from "../components/footer.astro";
const notes = [
{
title: "some fancy image to see if the structuring works",
date: "67-67-67",
link: "/"
}
];
---

<Home>
	<h1 class="page-title">arts</h1>
	<p class="page-subtitle">things i've drawn / tried to draw over the years. it's not some "hobby"
	i just picked it on a whim so don't expect anything fancy.</p>

	<div class="list-container">
		{notes.map((post) => (
		<CleanIndex title={post.title} date={post.date} link={post.link} />
		))}
	</div>

	<div style="margin-top: auto;">
		<Footer />
	</div>
</Home>

<style>
.page-title {
	font-size: 1.5rem;
	margin: 0;
	color: var(--color-text-main);
}

.page-subtitle {
	font-size: 1.1rem;
	color: var(--color-text-muted);
	margin-top: 15px;
	margin-bottom: 40px;
}

.list-container {
	display: flex;
	flex-direction: column;
	width: 100%;
}
</style>
