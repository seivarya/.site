---
import Home from "../layouts/home.astro";
import CleanIndex from "../components/CleanIndex.astro";
import { getCollection } from "astro:content";

function compareFn(obj1, obj2) {
	if (obj1.data.date < obj2.data.date) {
		return 1;

	} else if (obj1.data.date > obj2.data.date) {
		return -1;

	} else {
		return 0;

	}
}

const objects = await getCollection("writings");
const writings = objects.sort(compareFn);

---

<Home>
	<h1 class="page-title">writings</h1>
	<p class="page-subtitle">
		personal thoughts.
	</p>

	<div class="list-container">
		{
			writings.map((write) => (
				<CleanIndex
					title={write.data.title}
					date={write.data.date}
					slug={write.id}
					collection="writings"
				/>
			))
		}
	</div>
</Home>

<style>
	.page-title {
		font-size: 1.5rem;
		margin: 0;
		color: var(--color-text-main);
	}

	.page-subtitle {
		font-size: 1.1rem;
		color: var(--color-text-muted);
		margin-top: 15px;
		margin-bottom: 40px;
	}

	.list-container {
		display: flex;
		flex-direction: column;
		width: 100%;
	}
</style>
