{
        "compatibility_date": "2026-03-26",
        "compatibility_flags": ["global_fetch_strictly_public"],
        "name": "self",
        "main": "@astrojs/cloudflare/entrypoints/server",
        "routes": [
                {
                        "pattern": "seivarya.in/*",
                        "zone_name": "seivarya.in",
                },
                {
                        "pattern": "www.seivarya.in/*",
                        "zone_name": "seivarya.in",
                },
        ],
        "assets": {
                "directory": "./dist",
                "binding": "ASSETS",
                "not_found_handling": "404-page",
        },
        "observability": {
                "enabled": true,
        },
}
